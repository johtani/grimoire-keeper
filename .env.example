# Bitwarden Secrets Manager
# 以下のシークレットはBitwarden Secrets Managerで管理します
# マシンアカウントのアクセストークンをここに設定してください
# 詳細: docs/development.md
BWS_ACCESS_TOKEN=your-bws-access-token-here

# 以下のシークレットはBitwarden Secrets Managerに登録してください
# - OPENAI_API_KEY
# - GOOGLE_API_KEY
# - JINA_API_KEY
# - SLACK_BOT_TOKEN
# - SLACK_SIGNING_SECRET
# - SLACK_APP_TOKEN

# Services（非秘密の設定値）
BACKEND_API_URL=http://api:8000
WEAVIATE_HOST=localhost
WEAVIATE_PORT=8080
DATABASE_PATH=./grimoire.db

# OpenTelemetry
OTEL_EXPORTER_OTLP_ENDPOINT=http://host.docker.internal:4317
OTEL_SERVICE_NAME=grimoire-keeper
OTEL_RESOURCE_ATTRIBUTES=service.namespace=grimoire-keeper
