# BWS_ACCESS_TOKEN は ~/.config/bws.env に保存してください（このファイルには記載不要）
# mkdir -p ~/.config && echo 'BWS_ACCESS_TOKEN=your-token' > ~/.config/bws.env && chmod 600 ~/.config/bws.env
# 詳細: docs/development.md

# 以下のシークレットはBitwarden Secrets Managerに登録してください
# - OPENAI_API_KEY
# - JINA_API_KEY
# - SLACK_BOT_TOKEN
# - SLACK_SIGNING_SECRET
# - SLACK_APP_TOKEN
# クラウドLLM (Gemini等) を使う場合は追加:
# - LLM_API_KEY  (例: Google API Key)

# Services（非秘密の設定値）
BACKEND_API_URL=http://api:8000
WEAVIATE_HOST=localhost
WEAVIATE_PORT=8080
DATABASE_PATH=./grimoire.db

# LLM設定（環境変数で切り替え可能）
# ローカルLLM (llama-swap + llama.cpp):
LLM_MODEL=openai/qwen3-35b
LLM_API_BASE=http://localhost:8080/v1
LLM_API_KEY=dummy
# クラウドLLM (Gemini) に切り替える場合:
# LLM_MODEL=gemini/gemini-2.5-flash-lite
# LLM_API_KEY=<GOOGLE_API_KEY>  # BWSから注入
# LLM_API_BASE=  # 空にする

# OpenTelemetry
OTEL_EXPORTER_OTLP_ENDPOINT=http://host.docker.internal:4317
OTEL_SERVICE_NAME=grimoire-keeper
OTEL_RESOURCE_ATTRIBUTES=service.namespace=grimoire-keeper
